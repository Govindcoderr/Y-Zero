# .env.example - Environment Variables Template
# Copy this file to .env and fill in your values

# Groq API Key (Required)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI API Key (if using OpenAI instead of Groq)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Streamlit Configuration
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_TOOLBAR_MODE=minimal

# Optional: Database Configuration (for future use)
# DATABASE_URL=sqlite:///./workflows.db

# Optional: Logging
LOG_LEVEL=INFO
LOG_FILE=app.log


 
# Elasticsearch connection
ELASTICSEARCH_URL=http://localhost:9200
 
# If your ES has auth (Elastic Cloud or secured self-hosted):
# ELASTICSEARCH_USER=elastic
# ELASTICSEARCH_PASSWORD=your_password_here
 
# Index name (default: yzero_nodes — change if needed)
ES_NODE_INDEX=yzero_nodes
 
# ─────────────────────────────────────────────────────────────────
# For Elastic Cloud (managed), replace URL with your cloud endpoint:
# ELASTICSEARCH_URL=https://your-deployment.es.region.cloud.es.io:9243
# ELASTICSEARCH_USER=elastic
# ELASTICSEARCH_PASSWORD=cloud_password_here
# ─────────────────────────────────────────────────────────────────
